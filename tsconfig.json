{
  "extends": "astro/tsconfigs/base",
  "include": [".astro/types.d.ts", "**/*", "../back/src/dto"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@styles/*": ["./src/styles/*"],
